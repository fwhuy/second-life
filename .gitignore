__pycache__/
*.pyc
.venv/
# Image corpora are regenerable from scripts/; their metadata is not. Patterns are
# **/-prefixed because a pattern with an interior slash anchors to this file's
# directory, and every data dir actually lives under model/.
**/data/raw/
**/data/leaked/
**/data/.hf_cache/
# The 1.3GB unified corpus rebuilds from scripts/download_unified_datasets.py, but
# manifest.csv and trashnet_provenance.csv are the audit trail proving which files
# are disguised TrashNet — they stay committed, as do data/splits_unified/.
**/data/unified_waste/included/
**/data/unified_waste/excluded/
checkpoints/
*.pth
*.pt
.DS_Store
._*
Thumbs.db
~$*
.ipynb_checkpoints/
gradio_cached_examples/

# Local test inputs and course/design reference files
/bottle.jpeg
/cat.jpg

# Paper drafts, references, generated figures, and final document are local course
# deliverables collected outside the model and website trees.
/papers/

# Archives are build outputs, not sources. The handoff zip is rebuilt by copying
# handoff/ into a staging folder and zipping it; hyperparameter_tuning.zip is a
# snapshot of the directory of the same name, which IS committed.
/trashnet-train-FINAL-*.zip
/waste-classifier-handoff.zip
**/hyperparameter_tuning.zip

# Generated by model/paper/make_figures.py from the committed split metadata.
# The figures and the built PDF are committed (they are the deliverable); this
# only keeps Chrome's scratch output out.
**/paper/*.tmp.pdf

# Common local tooling output
/tmp/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.idea/
.vscode/
*.log
*.tmp
nohup.out

# macOS / editor cruft beyond .DS_Store
.AppleDouble
.Spotlight-V100
.Trashes
*.swp
*~

# splits ARE committed (data/splits/, data/splits_unified/), reports ARE committed
issues.md

# Deployment scratch: server setup notes and prompts, useful locally but not
# part of the project record.
/deploy/

.superpowers/
